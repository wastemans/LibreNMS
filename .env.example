# Copy this file to .env and fill in your values.
# .env is gitignored - never commit it.

# Host directory for all persistent data (DB, LibreNMS RRD/logs/config).
# Must be an absolute path. Created automatically on first run.
# This directory is NOT wiped by restart-stack.sh or upgrade-stack.sh.
# Only destructive-recreate.sh and destroy-stack.sh will remove it.
DATA_DIR="/opt/monitor_stack"

# Timezone (e.g. Europe/London, Australia/Sydney, America/New_York)
TZ="UTC"

# DNS server for all containers
DNS_SERVER="10.0.0.1"

# Canonical web URL (https + hostname users type), e.g. https://lnms.i
APP_URL="https://your-host"

# Database credentials
DB_ROOT_PASSWORD="change_me"
DB_USER="librenms"
DB_PASSWORD="change_me"
DB_NAME="librenms"

# SNMP community string used to poll devices
SNMP_COMMUNITY="public"

# Subnet(s) to auto-discover — quote if multiple, space-separated
# e.g. "10.0.0.0/24" or "10.0.0.0/24 192.168.1.0/24"
DISCOVERY_SUBNET="10.0.0.0/24"

# Days to retain syslog entries
SYSLOG_PURGE_DAYS="30"

# Admin account — updated when the bootstrap (scan) container runs after compose up
LNMS_ADMIN_USER="admin"
LNMS_ADMIN_PASS="change_me"

# API token for importing the full alert rule collection on bootstrap (plain hex, 32 chars).
# Generate: openssl rand -hex 16
# Do not use quotes or special characters in the token (SQL-safe hex only).
LNMS_API_TOKEN=""

# Set to 0 to skip importing all rules from alert_rules.json (default: 1)
IMPORT_ALERT_COLLECTION="1"

# Set to 0 to skip importing service checks from services.json (default: 1). Copy services.json.example → services.json.
# Runs after the discovery scan so devices exist before services are attached.
IMPORT_SERVICES="1"
